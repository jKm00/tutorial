  auth: inherit
}

body:json {
  {
    "items": [
      { "id": "item-id-1", "quantity": 2 },
      { "id": "item-id-2", "quantity": 1 }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
